{
  "name": "ashina-task-tracker",
  "displayName": "MD Task Tracker",
  "description": "",
  "version": "0.1.1",
  "publisher": "AshinaLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/DorukhanDoruk/md-task-tracker.git"
  },
  "author": "DorukhanDoruk",
  "license": "MIT",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-tasks-explorer",
          "title": "MD Tasks",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "MD Task Tracker",
      "properties": {
        "mdTaskTracker.excludePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of relative paths to exclude from task tracking."
        }
      }
    },
    "views": {
      "md-tasks-explorer": [
        {
          "id": "md-tasks-view",
          "name": "Task Progress",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "md-tasks-tracker.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "md-tasks-tracker.openAndHighlightTasks",
        "title": "Open File and Highlight Tasks",
        "icon": "$(go-to-file)"
      },
      {
        "command": "md-tasks-tracker.excludePath",
        "title": "Exclude from Tracking",
        "icon": "$(close)"
      },
      {
        "command": "md-tasks-tracker.clearExclusions",
        "title": "Clear All Exclusions",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "md-tasks-tracker.refresh",
          "when": "view == md-tasks-view",
          "group": "navigation"
        },
        {
          "command": "md-tasks-tracker.clearExclusions",
          "when": "view == md-tasks-view",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "md-tasks-tracker.excludePath",
          "when": "view == md-tasks-view",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}